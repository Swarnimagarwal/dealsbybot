# ── Required ──────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Your Telegram channel ID (e.g. @MyDealsChannel or -1001234567890)
CHANNEL_ID=YOUR_CHANNEL_ID

# ── Affiliate ─────────────────────────────────────────────────────────────────
AMAZON_AFFILIATE_ID=dealify01-21

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often to post deals (in minutes). Default: 60
POST_INTERVAL_MINUTES=60

# ── Deal Filters ──────────────────────────────────────────────────────────────
# Minimum discount percentage required to post a deal. Default: 30
MIN_DISCOUNT=30

# Minimum average star rating. Default: 4.0
MIN_RATING=4.0

# Minimum number of customer reviews. Default: 100
MIN_REVIEWS=100

# ── Advanced (optional) ───────────────────────────────────────────────────────
# Path to the SQLite database file. Default: data/deals.db
DB_PATH=data/deals.db

# Days before the same product can be reposted. Default: 30
DUPLICATE_WINDOW_DAYS=30

# HTTP request timeout in seconds. Default: 15
REQUEST_TIMEOUT=15

# Delay between scraper requests in seconds. Default: 2.0
REQUEST_DELAY_SECONDS=2.0

# Maximum number of deals posted per scheduler run. Default: 5
MAX_DEALS_PER_RUN=5

# Amazon domain to scrape. Default: amazon.in
AMAZON_DOMAIN=amazon.in
